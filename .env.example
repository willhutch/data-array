# Copy to .env.local and fill in values. Never commit .env.local.

# Google Sheets API key (fallback auth, only works for publicly-shared sheets)
API_KEY=

# Google OAuth client (used for NextAuth sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Service account (preferred auth) - lets the backend read private sheets
# without making them public. Share the target sheet with this service
# account's email as Viewer.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=